<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".FeedGrupoActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Barra de acciones del grupo -->
    <LinearLayout
        android:id="@+id/groupActionsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_dark"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout">

        <!-- Estadísticas del grupo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:gravity="center_vertical">

            <!-- ✅ MEJORA: Miembros clickeable para ver lista -->
            <TextView
                android:id="@+id/tvMiembrosCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Miembros"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:layout_marginHorizontal="12dp"
                android:background="@color/divider" />

            <!-- ✅ NUEVO: Contador de contenido -->
            <TextView
                android:id="@+id/tvContenidoCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 archivos"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnirseSalir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unirse al Grupo"
                android:textColor="@color/black"
                app:backgroundTint="@color/primary"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarGrupo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Eliminar Grupo"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#FF5252"
                app:strokeColor="#FF5252"
                app:cornerRadius="8dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ✅ NUEVO: Estado vacío cuando no hay contenido -->
    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp"
        app:layout_constraintTop_toBottomOf="@+id/groupActionsLayout"
        app:layout_constraintBottom_toTopOf="@+id/player_view">

        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aún no hay contenido en este grupo.\n\nÚnete y sé el primero en compartir música o videos."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Lista de contenido multimedia -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFeed"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/player_view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/groupActionsLayout" />

    <!-- Player de reproducción -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/black"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:resize_mode="fit"
        app:show_timeout="0"
        app:use_controller="true" />

    <!-- FAB para subir contenido -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSubirContenido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@drawable/baseline_file_upload_24"
        android:visibility="gone"
        app:backgroundTint="@color/primary"
        app:layout_constraintBottom_toTopOf="@+id/player_view"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/black" />

</androidx.constraintlayout.widget.ConstraintLayout>